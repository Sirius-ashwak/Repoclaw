# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Vercel Configuration (Legacy - will be replaced by AWS)
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_vercel_team_id

# LLM API Configuration (Legacy - will be replaced by AWS Bedrock)
LLM_API_KEY=your_llm_api_key
LLM_API_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-beta

# Vercel KV Configuration (Legacy - will be replaced by DynamoDB)
KV_URL=your_kv_url
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS DynamoDB
DYNAMODB_TABLE_NAME=repoclaw-sessions
DYNAMODB_ENDPOINT=  # Leave empty for production, set for LocalStack

# AWS S3
S3_BUCKET_NAME=repoclaw-artifacts
S3_ENDPOINT=  # Leave empty for production, set for LocalStack

# AWS Bedrock
BEDROCK_REGION=ap-south-1

# AWS Lambda
LAMBDA_SANDBOX_FUNCTION=repoclaw-code-sandbox

# AWS Translate
TRANSLATE_TERMINOLOGY_NAME=  # Optional: custom terminology for technical terms

# LocalStack (for local development only)
LOCALSTACK_ENDPOINT=  # Set to http://localhost:4566 for local development

# Ollama (for offline mode)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3

# Optional: Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
